---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { getEventos, getEventoById, getEventoStatus, buildGoogleCalendarUrl } from '../../lib/eventos.js';

export async function getStaticPaths() {
  const eventos = await getEventos();

  return eventos.map((evento) => ({
    params: { id: evento.id },
  }));
}

const { id } = Astro.params;
const evento = await getEventoById(id as string);

if (!evento) {
  return Astro.redirect('/404');
}

const calendarUrl = buildGoogleCalendarUrl(evento);
const status = getEventoStatus(evento);

const statusColors: Record<string, string> = {
  'Próximo': 'bg-emerald-900 text-emerald-200 border border-emerald-700',
  'Pasado': 'bg-slate-800 text-slate-300 border border-slate-600',
  'A confirmar': 'bg-amber-900 text-amber-200 border border-amber-700',
};
const statusColor = statusColors[status] ?? statusColors['A confirmar'];

const siteUrl = import.meta.env.PUBLIC_SITE_URL?.trim().replace(/\/$/, '') || Astro.site?.href.replace(/\/$/, '');
const detailUrl = siteUrl ? new URL(`/eventos/${evento.id}`, siteUrl).toString() : undefined;
const modalidad = evento.modalidad.toLowerCase();
const eventAttendanceMode = modalidad.includes('online') && modalidad.includes('presencial')
  ? 'https://schema.org/MixedEventAttendanceMode'
  : modalidad.includes('online')
    ? 'https://schema.org/OnlineEventAttendanceMode'
    : 'https://schema.org/OfflineEventAttendanceMode';
const eventStatus = status === 'Pasado'
  ? 'https://schema.org/EventCompleted'
  : 'https://schema.org/EventScheduled';
const eventStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: evento.nombre,
  description: evento.descripcion,
  eventStatus,
  eventAttendanceMode,
  ...(evento.fechaInicio ? { startDate: evento.fechaInicio } : {}),
  ...(evento.fechaFin ? { endDate: evento.fechaFin } : {}),
  ...(detailUrl ? { url: detailUrl } : {}),
  location: modalidad.includes('online') && !modalidad.includes('presencial')
    ? {
        '@type': 'VirtualLocation',
        url: evento.urlOficial ?? detailUrl ?? '/',
      }
    : {
        '@type': 'Place',
        name: evento.lugar,
        ...(evento.direccion ? { address: evento.direccion } : {}),
      },
  offers: {
    '@type': 'Offer',
    price: evento.precio === 'Gratis' || evento.precio === 'Gratuito' ? '0' : evento.precio ?? 'A confirmar',
    priceCurrency: 'ARS',
    availability: 'https://schema.org/InStock',
    ...(evento.urlOficial ? { url: evento.urlOficial } : {}),
  },
};
---

<Layout
  title={`${evento.nombre} — RadarTech BA`}
  description={evento.resumen}
  canonicalPath={`/eventos/${evento.id}`}
  type="article"
  structuredData={eventStructuredData}
>
  <Header />

  <main id="contenido-principal" class="max-w-4xl mx-auto px-4 py-10 space-y-8">
    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent-primary)] transition-colors" data-reveal>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Volver a todos los eventos
    </a>

    <!-- Event header -->
    <div
      class="card-surface p-6 md:p-8 space-y-6"
      data-reveal
      data-event-status-scope
      data-fecha-fin={evento.fechaFin}
      data-confirmado={String(evento.confirmado !== false)}
      data-estado-manual={evento.estadoManual ?? ''}
    >
      <div class="flex items-start justify-between gap-4">
        <h1 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] leading-tight">
          {evento.nombre}
        </h1>
        <span class={`shrink-0 pill text-sm ${statusColor}`} data-event-status data-event-status-extra-class="text-sm">{status}</span>
      </div>

      <!-- Description -->
      <p class="text-[var(--color-text-muted)] leading-relaxed">{evento.descripcion}</p>

      <!-- Meta grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 border-t border-[var(--color-border)] pt-6">
        <!-- Date -->
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-[var(--color-accent-cyan)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/>
            <path d="M16 2v4M8 2v4M3 10h18" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">Fecha</p>
            <p class="text-sm font-medium text-[var(--color-text)]">{evento.fechaTexto}</p>
          </div>
        </div>

        <!-- Place -->
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-[var(--color-accent-cyan)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke-width="1.5"/>
            <circle cx="12" cy="9" r="2.5" stroke-width="1.5"/>
          </svg>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">Lugar</p>
            <p class="text-sm font-medium text-[var(--color-text)]">{evento.lugar}</p>
            {evento.direccion && (
              <p class="text-xs text-[var(--color-text-muted)] mt-0.5">{evento.direccion}</p>
            )}
          </div>
        </div>

        <!-- Modality -->
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-[var(--color-accent-cyan)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2" stroke-width="1.5"/>
            <path d="M8 21h8M12 17v4" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">Modalidad</p>
            <p class="text-sm font-medium text-[var(--color-text)]">{evento.modalidad}</p>
          </div>
        </div>

        <!-- Category -->
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-[var(--color-accent-cyan)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 7h.01M7 12h.01M7 17h.01M12 7h.01M12 12h.01M12 17h.01M17 7h.01M17 12h.01M17 17h.01" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">Categoría</p>
            <div class="flex flex-wrap gap-1.5 mt-1">
              {evento.categorias.map((cat) => (
                <span class="pill bg-indigo-900 text-indigo-200">{cat}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Price -->
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-[var(--color-accent-cyan)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <div>
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">Precio</p>
            <p class="text-sm font-medium">
              {evento.precio === 'Gratis' ? (
                <span class="text-emerald-400">Gratis</span>
              ) : evento.precio === 'A confirmar' ? (
                <span class="text-amber-400">A confirmar</span>
              ) : evento.precio ?? '—'}
            </p>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-[var(--color-border)]">
        {evento.urlOficial && (
          <a
            href={evento.urlOficial}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Abrir sitio oficial de ${evento.nombre}`}
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-primary)] border border-[var(--color-accent-primary)] rounded-lg px-4 py-2 hover:bg-[var(--color-accent-primary)] hover:text-[var(--color-bg)] transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Sitio oficial
          </a>
        )}

        {calendarUrl ? (
          <a
            href={calendarUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Agregar ${evento.nombre} a Google Calendar`}
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-cyan)] border border-[var(--color-accent-cyan)] rounded-lg px-4 py-2 hover:bg-[var(--color-accent-cyan)] hover:text-[var(--color-bg)] transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/>
              <path d="M16 2v4M8 2v4M3 10h18" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M8 14h.01M12 14h.01M16 14h.01M8 17h.01M12 17h.01M16 17h.01" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Agregar a Google Calendar
          </a>
        ) : (
          <span
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-text-muted)] opacity-50 border border-[var(--color-border)] rounded-lg px-4 py-2 cursor-not-allowed"
            title="Fecha o asistencia no confirmada"
            aria-disabled="true"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/>
              <path d="M16 2v4M8 2v4M3 10h18" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M8 14h.01M12 14h.01M16 14h.01M8 17h.01M12 17h.01M16 17h.01" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Agregar a Google Calendar
          </span>
        )}
      </div>
    </div>
  </main>
</Layout>
