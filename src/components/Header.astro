---
// Header component — brand name and description
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-surface)]/80 backdrop-blur-sm sticky top-0 z-10">
  <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
    <div>
      <a
        href="/"
        aria-label="RadarTech BA - ir al inicio"
        class="inline-block text-xl font-bold text-[var(--color-accent-primary)] tracking-tight hover:text-[var(--color-accent-cyan)] transition-colors"
      >
        RadarTech BA
      </a>
      <p class="text-xs text-[var(--color-text-muted)] mt-0.5">
        Eventos tech en Buenos Aires y Argentina para aprender, conectar y crecer
      </p>
    </div>
  </div>
</header>
